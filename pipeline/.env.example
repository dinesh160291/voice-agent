# Aurora Hotel voice agent - environment configuration
# Copy this file to .env and fill in real values. Never commit .env (it holds secrets).
# Every variable is optional; the code falls back to the defaults shown here.

# ---------------------------------------------------------------------------
# Provider selection (providers.py)
# ---------------------------------------------------------------------------
# Which brain to use: mock (offline, canned replies) | groq | openai
PROVIDER=mock

# API key for the chosen provider (only the matching one is required)
# Groq: free tier at https://console.groq.com -> API Keys
GROQ_API_KEY=gsk_your_key_here
# OpenAI: paid credits required, https://platform.openai.com
# OPENAI_API_KEY=sk-your_key_here

# Model overrides (defaults come from the provider preset in providers.py)
# LLM_MODEL=
# STT_MODEL=          # groq default: whisper-large-v3-turbo | openai: whisper-1
# STT_PROMPT=         # bias phrase handed to the transcriber
# TTS_MODEL=
# TTS_VOICE=
# TTS_INSTRUCTIONS=   # style hint for provider TTS

# Text-to-speech backend: provider (API voice) | system (SYSTEM_TTS_CMD) | print
# TTS_BACKEND=provider
# SYSTEM_TTS_CMD=     # local command for TTS_BACKEND=system (e.g. a say/espeak equivalent)

# ---------------------------------------------------------------------------
# Microphone loop (voice_loop.py)
# ---------------------------------------------------------------------------
# SAMPLE_RATE=16000
# VAD_AGGRESSIVENESS=3        # 0 (lenient) .. 3 (strict); 3 holds on this machine's room noise
# ENDPOINT_SILENCE_MS=600     # silence that ends a turn (20 x 30 ms frames)
# AUDIO_PLAYER_CMD=           # local command used to play replies

# ---------------------------------------------------------------------------
# Telemetry (telemetry.py)
# ---------------------------------------------------------------------------
# TELEMETRY_INCLUDE_CONTENT=false   # true = traces keep user/agent text (dev only)
# TELEMETRY_JSONL=                  # override the trace output path

# ---------------------------------------------------------------------------
# LiveKit demo (livekit/create_room.py, livekit/talk_server.py)
# ---------------------------------------------------------------------------
# On Windows prefer 127.0.0.1 over localhost (avoids the IPv6 ::1 reset).
# LIVEKIT_URL=http://127.0.0.1:7880
# LIVEKIT_API_KEY=devkey
# LIVEKIT_API_SECRET=secret
# LIVEKIT_ROOM=aurora-demo-room
# TALK_HOST=127.0.0.1
# TALK_PORT=5173
